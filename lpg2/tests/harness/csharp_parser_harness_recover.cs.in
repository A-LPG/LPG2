using System;
using LPG2.Runtime;

class StubLexStream : LexStream
{
    public StubLexStream()
        : base(new char[] { 'a', 'b', 'c', ' ' }, "generated-test")
    {
    }

    public override string[] orderedExportedSymbols()
    {
        return @EXPECT_PREFIX@sym.orderedTerminalSymbols;
    }
}

class NopVisitor : @EXPECT_PREFIX@.AbstractVisitor
{
    public override void unimplementedVisitor(string s) { }
}

public class CSharpParserHarness
{
    static void Seed(IPrsStream stream, int[] kinds)
    {
        stream.makeToken(0, 0, 0); // bad token first
        for (int i = 0; i < kinds.Length; i++)
            stream.makeToken(i + 1, i + 1, kinds[i]);
        stream.setStreamLength(stream.getSize());
    }

    public static int Main(string[] args)
    {
        // 1) A well-formed parse builds the normal AST: "a b c" -> Root(a, Missing(b c)).
        StubLexStream lex = new StubLexStream();
        @EXPECT_PREFIX@ parser = new @EXPECT_PREFIX@(lex);
        Seed(parser.getIPrsStream(), new int[] {
            @EXPECT_PREFIX@sym.TK_a,
            @EXPECT_PREFIX@sym.TK_b,
            @EXPECT_PREFIX@sym.TK_c,
            @EXPECT_PREFIX@sym.TK_EOF_TOKEN,
        });
        @EXPECT_PREFIX@.Ast root = parser.parser();
        if (root == null)
            return 2;
        if (root.GetRuleIndex() != @EXPECT_PREFIX@sym.RULE_S)
            return 3;
        root.accept(new NopVisitor());

        // 2) Prosthetic-AST closed loop. This mirrors the path the backtracking
        //    parser takes when it replays a nonterminal ErrorToken inserted by
        //    scope recovery for a %Recover symbol:
        //        ra.getProstheticAst()[prs.getProsthesisIndex(kind)](token)
        ProstheticAst[] prosthetic = parser.getProstheticAst();
        if (prosthetic == null)
            return 4;

        IToken errorToken = parser.getIPrsStream().getIToken(1); // stand-in error token
        ParseTable prs = parser.getParseTable();
        int ntOffset = prs.getNtOffset();
        int numNonterminals = prs.getNumNonterminals();
        int synthesized = 0;
        for (int kind = ntOffset + 1; kind <= ntOffset + numNonterminals; kind++)
        {
            int slot = prs.getProsthesisIndex(kind);
            if (slot < 0 || slot >= prosthetic.Length)
                continue;
            ProstheticAst factory = prosthetic[slot];
            if (factory == null)
                continue;
            IAst node = factory(errorToken);
            if (node == null)
                return 5;
            if (node.getLeftIToken() != errorToken)
                return 6;
            synthesized++;
        }
        if (synthesized == 0) // the %Recover nonterminal must own a factory
            return 7;

        return 0;
    }
}
