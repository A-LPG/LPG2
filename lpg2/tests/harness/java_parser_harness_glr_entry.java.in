import lpg.runtime.*;

class StubLexStream extends LexStream {
    StubLexStream() {
        initialize(new char[8], "glr-entry-test");
    }

    @Override
    public String[] orderedExportedSymbols() {
        return @EXPECT_PREFIX@sym.orderedTerminalSymbols;
    }
}

public class JavaParserHarness {
    static void seed(IPrsStream stream, int kind) {
        stream.makeToken(0, 0, 0); // bad token first
        stream.makeToken(1, 1, kind);
        stream.makeToken(2, 2, @EXPECT_PREFIX@sym.TK_EOF_TOKEN);
        stream.setStreamLength(stream.getSize());
    }

    public static void main(String[] args) {
        {
            StubLexStream lex = new StubLexStream();
            @EXPECT_PREFIX@ parser = new @EXPECT_PREFIX@(lex);
            seed(parser.getIPrsStream(), @EXPECT_PREFIX@sym.TK_A_TOKEN);
            @EXPECT_PREFIX@.Ast root = parser.parser();
            if (!(root instanceof @EXPECT_PREFIX@.A))
                System.exit(2);
        }

        {
            StubLexStream lex = new StubLexStream();
            @EXPECT_PREFIX@ parser = new @EXPECT_PREFIX@(lex);
            seed(parser.getIPrsStream(), @EXPECT_PREFIX@sym.TK_B_TOKEN);
            @EXPECT_PREFIX@.Ast root = parser.parseB();
            if (!(root instanceof @EXPECT_PREFIX@.B))
                System.exit(3);
        }

        System.exit(0);
    }
}
