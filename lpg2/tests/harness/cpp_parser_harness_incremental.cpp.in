#include "@EXPECT_PREFIX@.h"
#include "@EXPECT_PREFIX@sym.h"
#include "lpg2/LexStream.h"

#include <vector>

struct StubLexStream : LexStream {
    StubLexStream()
    {
        shared_ptr_wstring chars(std::wstring(L"aaa "));
        initialize(chars, L"generated-incremental-test");
    }

    std::vector<std::wstring> orderedExportedSymbols() override
    {
        return @EXPECT_PREFIX@sym::orderedTerminalSymbols;
    }
};

static void seed(IPrsStream* stream, const std::vector<int>& kinds)
{
    stream->resetTokenStream();
    stream->makeToken(0, 0, 0);
    for (int i = 0; i < (int)kinds.size(); ++i)
        stream->makeToken(i + 1, i + 1, kinds[i]);
    stream->setStreamLength(stream->getSize());
}

int main()
{
    StubLexStream lex;
    @EXPECT_PREFIX@ parser(&lex);
    IPrsStream* stream = parser.getIPrsStream();

    // 1) Baseline parse
    seed(stream, {
        @EXPECT_PREFIX@sym::TK_a,
        @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
    });
    if (!parser.parser())
        return 2;

    // 2) Multi-token stream, then damage-offset truncate
    seed(stream, {
        @EXPECT_PREFIX@sym::TK_a,
        @EXPECT_PREFIX@sym::TK_a,
        @EXPECT_PREFIX@sym::TK_a,
        @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
    });
    const int before = stream->getSize();
    if (before < 4)
        return 3;

    Tuple<IToken*> affected = stream->incrementalResetAtCharacterOffset(2);
    if (affected.size() < 1)
        return 4;
    if (stream->getSize() >= before)
        return 5;

    // 3) Rebuild token stream after damage and parse again
    seed(stream, {
        @EXPECT_PREFIX@sym::TK_a,
        @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
    });
    @EXPECT_PREFIX@::Ast* root = parser.parser();
    if (!root)
        return 6;
    if (root->getRuleIndex() != @EXPECT_PREFIX@sym::RULE_S)
        return 7;
    return 0;
}
