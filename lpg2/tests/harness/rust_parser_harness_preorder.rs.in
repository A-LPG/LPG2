#![allow(
    dead_code,
    non_camel_case_types,
    non_snake_case,
    non_upper_case_globals,
    private_interfaces,
    unused_imports,
    unused_mut,
    unused_variables
)]

use lpg2::prelude::*;
use lpg2::traits::ParseTable;
use std::any::Any;
use std::cell::RefCell;
use std::rc::Rc;

include!("@EXPECT_PREFIX@sym.rs");
include!("@EXPECT_PREFIX@prs.rs");
include!("@EXPECT_PREFIX@.rs");

#[cfg(test)]
mod tests {
    use super::*;

    fn parser_with(kinds: &[i32]) -> Box<@EXPECT_PREFIX@> {
        let parser = @EXPECT_PREFIX@::new(None).expect("construct generated parser");
        let stream = parser.get_i_prs_stream();
        {
            let mut stream = stream.borrow_mut();
            stream.make_token(0, 0, 0);
            for (index, kind) in kinds.iter().copied().enumerate() {
                stream.make_token(index as i32, index as i32, kind);
            }
            let size = stream.get_size();
            stream.set_stream_length(size);
        }
        parser
    }

    struct OrderVisitor {
        events: Vec<&'static str>,
    }

    impl IAstVisitor for OrderVisitor {
        fn pre_visit(&mut self, _element: &dyn IAst) -> bool {
            self.events.push("pre");
            true
        }
        fn post_visit(&mut self, _element: &dyn IAst) {
            self.events.push("post");
        }
    }

    impl PreOrderVisitor for OrderVisitor {
        fn VisitRoot(&mut self, _n: &Root) -> bool {
            self.events.push("VisitRoot");
            true
        }
        fn EndVisitRoot(&mut self, _n: &Root) {
            self.events.push("EndVisitRoot");
        }
        fn VisitItem(&mut self, _n: &Item) -> bool {
            self.events.push("VisitItem");
            true
        }
        fn EndVisitItem(&mut self, _n: &Item) {
            self.events.push("EndVisitItem");
        }
        fn VisitAstToken(&mut self, _n: &AstToken) -> bool {
            self.events.push("VisitAstToken");
            true
        }
        fn EndVisitAstToken(&mut self, _n: &AstToken) {
            self.events.push("EndVisitAstToken");
        }
        fn Visit(&mut self, n: Rc<dyn IAst>) -> bool {
            if let Some(node) = downcast_ast::<Root>(n.clone()) {
                return self.VisitRoot(&node);
            }
            if let Some(node) = downcast_ast::<Item>(n.clone()) {
                return self.VisitItem(&node);
            }
            if let Some(node) = downcast_ast::<AstToken>(n.clone()) {
                return self.VisitAstToken(&node);
            }
            false
        }
        fn EndVisit(&mut self, n: Rc<dyn IAst>) {
            if let Some(node) = downcast_ast::<Root>(n.clone()) {
                self.EndVisitRoot(&node);
                return;
            }
            if let Some(node) = downcast_ast::<Item>(n.clone()) {
                self.EndVisitItem(&node);
                return;
            }
            if let Some(node) = downcast_ast::<AstToken>(n.clone()) {
                self.EndVisitAstToken(&node);
            }
        }
    }

    #[test]
    fn preorder_visit_order() {
        let mut parser = parser_with(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let payload = parser
            .parser()
            .expect("parse should succeed")
            .expect("AST payload");
        let ast = unbox_ast(payload.as_ref()).expect("Rc<dyn IAst>");
        let root = downcast_ast::<Root>(ast).expect("Root");

        let mut visitor = OrderVisitor { events: Vec::new() };
        root.accept(&mut visitor);

        assert_eq!(
            visitor.events,
            [
                "pre",
                "VisitRoot",
                "pre",
                "VisitItem",
                "EndVisitItem",
                "post",
                "EndVisitRoot",
                "post",
            ]
        );
    }
}
