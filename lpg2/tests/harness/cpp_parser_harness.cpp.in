#include "@EXPECT_PREFIX@.h"
#include "@EXPECT_PREFIX@sym.h"
#include "lpg2/LexStream.h"

#include <cstdlib>
#include <fstream>
#include <sstream>
#include <string>
#include <vector>

struct StubLexStream : LexStream {
    StubLexStream()
    {
        // In-memory input so makeToken offsets stay in range without opening a file.
        shared_ptr_wstring chars(std::wstring(L"xa  "));
        initialize(chars, L"generated-test");
    }

    std::vector<std::wstring> orderedExportedSymbols() override
    {
        return @EXPECT_PREFIX@sym::orderedTerminalSymbols;
    }
};

struct NopVisitor : @EXPECT_PREFIX@::Visitor {
    void visit(@EXPECT_PREFIX@::AstToken*) override {}
    void visit(@EXPECT_PREFIX@::Root*) override {}
    void visit(@EXPECT_PREFIX@::Item*) override {}
    void visit(@EXPECT_PREFIX@::Ast* n) override
    {
        if (auto* t = dynamic_cast<@EXPECT_PREFIX@::AstToken*>(n)) {
            visit(t);
            return;
        }
        if (auto* r = dynamic_cast<@EXPECT_PREFIX@::Root*>(n)) {
            visit(r);
            return;
        }
        if (auto* item = dynamic_cast<@EXPECT_PREFIX@::Item*>(n)) {
            visit(item);
            return;
        }
    }
};

static void seed(IPrsStream* stream, const std::vector<int>& kinds)
{
    stream->makeToken(0, 0, 0); // bad token first
    for (int i = 0; i < (int)kinds.size(); ++i)
        stream->makeToken(i + 1, i + 1, kinds[i]);
    stream->setStreamLength(stream->getSize());
}

int main()
{
    StubLexStream lex;
    @EXPECT_PREFIX@ parser(&lex);
    seed(parser.getIPrsStream(), {
        @EXPECT_PREFIX@sym::TK_a,
        @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
    });
    @EXPECT_PREFIX@::Ast* root = parser.parser();
    if (!root)
        return 2;
    if (root->getRuleIndex() != @EXPECT_PREFIX@sym::RULE_S)
        return 3;
    if (!root->getLeftIToken() || !root->getRightIToken())
        return 4;
    NopVisitor v;
    root->accept(&v);

    // Cross-backend AST shape dump (S-expr): class + terminal + span.
    {
        auto* r = dynamic_cast<@EXPECT_PREFIX@::Root*>(root);
        if (!r || !r->getItem())
            return 8;
        IToken* tok = r->getItem()->getIToken();
        if (!tok)
            return 8;
        std::ostringstream dump;
        dump << "(Root (Item "
             << IcuUtil::ws2s(@EXPECT_PREFIX@sym::orderedTerminalSymbols[tok->getKind()])
             << " " << tok->getStartOffset() << " " << tok->getEndOffset() << "))";
        const std::string expected = "(Root (Item a 1 1))";
        if (dump.str() != expected)
            return 9;
        if (const char* path = std::getenv("LPG2_AST_DUMP_PATH")) {
            std::ofstream out(path);
            if (!out)
                return 10;
            out << dump.str() << "\n";
        }
    }

    // EOF-only should fail
    StubLexStream lex2;
    @EXPECT_PREFIX@ parser2(&lex2);
    seed(parser2.getIPrsStream(), { @EXPECT_PREFIX@sym::TK_EOF_TOKEN });
    if (parser2.parser() != nullptr)
        return 5;
    return 0;
}
