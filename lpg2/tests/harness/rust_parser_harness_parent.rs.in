#![allow(
    dead_code,
    non_camel_case_types,
    non_snake_case,
    non_upper_case_globals,
    private_interfaces,
    unused_imports,
    unused_mut,
    unused_variables
)]

use lpg2::prelude::*;
use lpg2::traits::ParseTable;
use std::any::Any;
use std::cell::RefCell;
use std::rc::Rc;

include!("@EXPECT_PREFIX@sym.rs");
include!("@EXPECT_PREFIX@prs.rs");
include!("@EXPECT_PREFIX@.rs");

#[cfg(test)]
mod tests {
    use super::*;

    fn parser_with(kinds: &[i32]) -> Box<@EXPECT_PREFIX@> {
        let parser = @EXPECT_PREFIX@::new(None).expect("construct generated parser");
        let stream = parser.get_i_prs_stream();
        {
            let mut stream = stream.borrow_mut();
            stream.make_token(0, 0, 0);
            for (index, kind) in kinds.iter().copied().enumerate() {
                stream.make_token(index as i32, index as i32, kind);
            }
            let size = stream.get_size();
            stream.set_stream_length(size);
        }
        parser
    }

    #[test]
    fn parent_saved_links_and_children() {
        let mut parser = parser_with(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let payload = parser
            .parser()
            .expect("parse should succeed")
            .expect("AST payload");
        let ast = unbox_ast(payload.as_ref()).expect("Rc<dyn IAst>");
        let root = downcast_ast::<Root>(ast).expect("Root");

        let item = root.get_Item().expect("child Item");
        let parent = item
            .get_parent()
            .expect("parent_saved should set parent on Item");
        assert!(downcast_ast::<Root>(parent).is_some());

        let children = root.get_children();
        assert_eq!(children.size(), 1);
        let all_children = root.get_all_children();
        assert_eq!(all_children.size(), 1);

        let as_iast: Rc<dyn IAst> = root.clone() as Rc<dyn IAst>;
        assert_eq!(as_iast.get_children().size(), 1);
        assert_eq!(as_iast.get_all_children().size(), 1);

        let child = unbox_ast(children.get(0).expect("child slot"))
            .expect("boxed child");
        assert!(downcast_ast::<Item>(child).is_some());
    }
}
