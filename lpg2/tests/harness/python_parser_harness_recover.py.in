import sys

# Runtime and generated modules are placed on PYTHONPATH by the test runner.
from lpg2 import LexStream
from @EXPECT_PREFIX@ import @EXPECT_PREFIX@, Root, Missing, AbstractVisitor
from @EXPECT_PREFIX@sym import @EXPECT_PREFIX@sym as sym


class StubLexStream(LexStream):
    def __init__(self):
        # In-memory input so makeToken offsets stay in range without a real file.
        super().__init__("generated-test", "abc   ")

    def orderedExportedSymbols(self):
        return sym.orderedTerminalSymbols


class NopVisitor(AbstractVisitor):
    def unimplementedVisitor(self, s):
        pass

    def visitAstToken(self, n, o=None):
        pass

    def visitRoot(self, n, o=None):
        pass

    def visitMissing(self, n, o=None):
        pass


def seed(stream, kinds):
    stream.makeToken(0, 0, 0)  # bad token first
    for i, k in enumerate(kinds):
        stream.makeToken(i + 1, i + 1, k)
    stream.setStreamLength(stream.getSize())


def main():
    # 1) A well-formed parse builds the normal AST:
    #    "a b c" -> Root(a, Missing(b c)).
    lex = StubLexStream()
    parser = @EXPECT_PREFIX@(lex)
    seed(parser.getIPrsStream(), [sym.TK_a, sym.TK_b, sym.TK_c, sym.TK_EOF_TOKEN])
    root = parser.parser()
    if root is None:
        sys.exit(2)
    if not isinstance(root, Root):
        sys.exit(3)
    if root.getLeftIToken() is None or root.getRightIToken() is None:
        sys.exit(3)
    root.acceptWithVisitor(NopVisitor())

    # 2) Prosthetic-AST closed loop. This is the path the BacktrackingParser
    #    takes when it replays a nonterminal ErrorToken inserted by scope
    #    recovery for a %Recover symbol:
    #        getProstheticAst()[getProsthesisIndex(kind)](token)
    #    We drive it directly: every recover nonterminal must resolve to a
    #    factory that synthesizes a non-null placeholder node.
    prosthetic = parser.getProstheticAst()
    if prosthetic is None:
        sys.exit(4)

    error_token = parser.getIPrsStream().getIToken(1)  # stand-in error token
    prs = parser.getParseTable()
    nt_offset = prs.getNtOffset()
    synthesized = 0
    for kind in range(nt_offset + 1, nt_offset + prs.getNumNonterminals() + 1):
        slot = prs.getProsthesisIndex(kind)
        if slot < 0 or slot >= len(prosthetic):
            continue
        factory = prosthetic[slot]
        if factory is None:
            continue
        node = factory(error_token)
        if node is None:
            sys.exit(5)
        if not isinstance(node, Missing):
            sys.exit(8)  # default prosthesis must be typed Missing*, not AstToken
        if node.getLeftIToken() is not error_token or node.getRightIToken() is not error_token:
            sys.exit(6)
        node.acceptWithVisitor(NopVisitor())
        synthesized += 1
    if synthesized == 0:  # the %Recover nonterminal must own a factory
        sys.exit(7)

    sys.exit(0)


if __name__ == "__main__":
    main()
