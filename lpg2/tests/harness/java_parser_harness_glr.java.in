import lpg.runtime.*;
import java.util.HashSet;
import java.util.IdentityHashMap;
import java.util.Set;

class StubLexStream extends LexStream {
    StubLexStream() {
        initialize(new char[32], "glr-test");
    }

    @Override
    public String[] orderedExportedSymbols() {
        return @EXPECT_PREFIX@sym.orderedTerminalSymbols;
    }
}

public class JavaParserHarness {
    static void seed(IPrsStream stream, int[] kinds) {
        stream.makeToken(0, 0, 0); // bad token first
        for (int i = 0; i < kinds.length; i++)
            stream.makeToken(i + 1, i + 1, kinds[i]);
        stream.setStreamLength(stream.getSize());
    }

    static int countAlts(IAst n) {
        int c = 0;
        for (IAst p = n; p != null; p = p.getNextAst())
            c++;
        return c;
    }

    static long countTrees(IAst n) {
        long total = 0;
        for (IAst p = n; p != null; p = p.getNextAst()) {
            @EXPECT_PREFIX@.E e = (@EXPECT_PREFIX@.E) p;
            if (e.getE() == null)
                total++;
            else
                total += countTrees(e.getE()) * countTrees(e.getE3());
        }
        return total;
    }

    static Set<String> shapes(IAst n) {
        Set<String> result = new HashSet<String>();
        IdentityHashMap<IAst, Boolean> seen = new IdentityHashMap<IAst, Boolean>();
        IToken chainLeft = null, chainRight = null;
        for (IAst p = n; p != null; p = p.getNextAst()) {
            if (seen.put(p, Boolean.TRUE) != null)
                throw new AssertionError("cycle in nextAst chain");
            if (chainLeft == null) {
                chainLeft = p.getLeftIToken();
                chainRight = p.getRightIToken();
            } else if (chainLeft.getILexStream() != p.getLeftIToken().getILexStream()
                    || chainRight.getILexStream() != p.getRightIToken().getILexStream()
                    || chainLeft.getTokenIndex() != p.getLeftIToken().getTokenIndex()
                    || chainRight.getTokenIndex() != p.getRightIToken().getTokenIndex()) {
                throw new AssertionError("different spans in nextAst chain");
            }

            @EXPECT_PREFIX@.E e = (@EXPECT_PREFIX@.E) p;
            if (e.getE() == null)
                result.add("n");
            else {
                for (String left : shapes(e.getE()))
                    for (String right : shapes(e.getE3()))
                        result.add("(" + left + right + ")");
            }
        }
        return result;
    }

    static int[] expressionKinds(int operands) {
        int[] kinds = new int[operands * 2];
        int i = 0;
        for (int n = 0; n < operands; n++) {
            kinds[i++] = @EXPECT_PREFIX@sym.TK_NUMBER;
            if (n + 1 < operands)
                kinds[i++] = @EXPECT_PREFIX@sym.TK_PLUS;
        }
        kinds[i] = @EXPECT_PREFIX@sym.TK_EOF_TOKEN;
        return kinds;
    }

    static @EXPECT_PREFIX@.Ast parse(int[] kinds) {
        StubLexStream lex = new StubLexStream();
        @EXPECT_PREFIX@ parser = new @EXPECT_PREFIX@(lex);
        seed(parser.getIPrsStream(), kinds);
        return parser.parser();
    }

    public static void main(String[] args) {
        // 1. Ambiguous: NUMBER PLUS NUMBER PLUS NUMBER → exactly 2 alts
        {
            @EXPECT_PREFIX@.Ast root = parse(new int[] {
                @EXPECT_PREFIX@sym.TK_NUMBER,
                @EXPECT_PREFIX@sym.TK_PLUS,
                @EXPECT_PREFIX@sym.TK_NUMBER,
                @EXPECT_PREFIX@sym.TK_PLUS,
                @EXPECT_PREFIX@sym.TK_NUMBER,
                @EXPECT_PREFIX@sym.TK_EOF_TOKEN,
            });
            if (root == null)
                System.exit(2);
            int n = countAlts(root);
            if (n != 2)
                System.exit(3);
            IAst alt = root.getNextAst();
            if (alt == null)
                System.exit(4);
            if (alt.getNextAst() != null)
                System.exit(5);
            IToken l0 = root.getLeftIToken(), r0 = root.getRightIToken();
            IToken l1 = alt.getLeftIToken(), r1 = alt.getRightIToken();
            if (l0 == null || r0 == null || l1 == null || r1 == null)
                System.exit(6);
            if (l0.getStartOffset() != l1.getStartOffset()
                    || r0.getEndOffset() != r1.getEndOffset())
                System.exit(7);
        }

        // 2. Nested ambiguity is retained exactly as a packed Catalan forest.
        {
            long[] catalan = { 1, 1, 2, 5, 14, 42, 132, 429 };
            for (int operands = 1; operands <= catalan.length; operands++) {
                @EXPECT_PREFIX@.Ast root = parse(expressionKinds(operands));
                long expected = catalan[operands - 1];
                if (root == null || countTrees(root) != expected)
                    System.exit(11 + operands);
                if (shapes(root).size() != expected)
                    System.exit(20 + operands);
            }
        }

        // 3. Unambiguous: NUMBER → no nextAst chain
        {
            @EXPECT_PREFIX@.Ast root = parse(new int[] {
                @EXPECT_PREFIX@sym.TK_NUMBER,
                @EXPECT_PREFIX@sym.TK_EOF_TOKEN,
            });
            if (root == null)
                System.exit(8);
            if (root.getNextAst() != null)
                System.exit(9);
            if (!(root instanceof @EXPECT_PREFIX@.E))
                System.exit(10);
        }

        // 4. Illegal: PLUS NUMBER → null (GLR v1: no error recovery/DiagnoseParser)
        {
            @EXPECT_PREFIX@.Ast root = parse(new int[] {
                @EXPECT_PREFIX@sym.TK_PLUS,
                @EXPECT_PREFIX@sym.TK_NUMBER,
                @EXPECT_PREFIX@sym.TK_EOF_TOKEN,
            });
            if (root != null)
                System.exit(11);
        }

        // 5. SPPF sharing: n=8 has 429 derivations but far fewer SPPF symbol nodes.
        {
            StubLexStream lex = new StubLexStream();
            @EXPECT_PREFIX@ parser = new @EXPECT_PREFIX@(lex);
            seed(parser.getIPrsStream(), expressionKinds(8));
            @EXPECT_PREFIX@.Ast root = parser.parser();
            if (root == null || countTrees(root) != 429)
                System.exit(30);
            GLRParser glr = (GLRParser) parser.getParser();
            SppfNode sppf = glr.getSppfRoot();
            if (sppf == null || sppf.getPacks().isEmpty())
                System.exit(31);
            int symbols = glr.getSppfSymbolCount();
            // Naive tree cloning would need >=429 internal nodes; shared SPPF is much smaller.
            if (symbols <= 0 || symbols >= 429)
                System.exit(32);
        }

        System.exit(0);
    }
}
