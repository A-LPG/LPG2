#![allow(
    dead_code,
    non_camel_case_types,
    non_snake_case,
    non_upper_case_globals,
    private_interfaces,
    unused_imports,
    unused_mut,
    unused_variables
)]

use lpg2::prelude::*;
use lpg2::traits::ParseTable;
use std::any::Any;
use std::cell::RefCell;
use std::rc::Rc;

include!("@EXPECT_PREFIX@sym.rs");
include!("@EXPECT_PREFIX@prs.rs");
include!("@EXPECT_PREFIX@.rs");

#[cfg(test)]
mod tests {
    use super::*;

    fn parser_with(kinds: &[i32]) -> Box<@EXPECT_PREFIX@> {
        let parser = @EXPECT_PREFIX@::new(None).expect("construct generated parser");
        let stream = parser.get_i_prs_stream();
        {
            let mut stream = stream.borrow_mut();
            stream.make_token(0, 0, 0);
            for (index, kind) in kinds.iter().copied().enumerate() {
                stream.make_token(index as i32, index as i32, kind);
            }
            let size = stream.get_size();
            stream.set_stream_length(size);
        }
        parser
    }

    fn parse_root(kinds: &[i32]) -> Rc<Root> {
        let mut parser = parser_with(kinds);
        let payload = parser
            .parser()
            .expect("parse list should succeed")
            .expect("AST payload");
        let ast = unbox_ast(payload.as_ref()).expect("Rc<dyn IAst>");
        downcast_ast::<Root>(ast).expect("root should downcast to Root")
    }

    #[test]
    fn list_singleton_size_and_element() {
        let root = parse_root(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let list = root.get_AList().expect("Root.get_AList");
        assert_eq!(list.size(), 1);
        let elem = list.get_a_at(0).expect("singleton element");
        assert!(downcast_ast::<AstToken>(elem).is_some());
    }

    #[test]
    fn list_of_two_copy_add_and_children() {
        let root = parse_root(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let list = root.get_AList().expect("Root.get_AList");
        assert_eq!(list.size(), 2);

        let first = list.get_a_at(0).expect("first element");
        let second = list.get_a_at(1).expect("second element");
        assert!(downcast_ast::<AstToken>(first.clone()).is_some());
        assert!(downcast_ast::<AstToken>(second.clone()).is_some());

        let children = list.get_children();
        assert_eq!(children.size(), 2);
        let all_children = list.get_all_children();
        assert_eq!(all_children.size(), 2);

        let as_iast: Rc<dyn IAst> = list.clone() as Rc<dyn IAst>;
        assert_eq!(as_iast.get_children().size(), 2);
    }
}
