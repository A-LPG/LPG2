#![allow(
    dead_code,
    non_camel_case_types,
    non_snake_case,
    non_upper_case_globals,
    private_interfaces,
    unused_imports,
    unused_mut,
    unused_variables
)]

use lpg2::expected_terminal_names;
use lpg2::prelude::*;
use lpg2::traits::ParseTable;
use std::any::Any;
use std::cell::RefCell;
use std::rc::Rc;

include!("@EXPECT_PREFIX@sym.rs");
include!("@EXPECT_PREFIX@prs.rs");
include!("@EXPECT_PREFIX@.rs");

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn start_state_includes_terminal_a() {
        let parser = @EXPECT_PREFIX@::new(None).expect("construct generated parser");
        let prs = parser.get_parse_table();
        let names = expected_terminal_names(prs, prs.get_start_state());
        assert!(
            names.iter().any(|n| n == "a"),
            "expected terminal `a` at start state, got {names:?}"
        );
    }
}
