#![allow(
    dead_code,
    non_camel_case_types,
    non_snake_case,
    non_upper_case_globals,
    private_interfaces,
    unused_imports,
    unused_mut,
    unused_variables
)]

use lpg2::prelude::*;
use lpg2::traits::ParseTable;
use std::any::Any;
use std::rc::Rc;

include!("@EXPECT_PREFIX@sym.rs");
include!("@EXPECT_PREFIX@prs.rs");
include!("@EXPECT_PREFIX@.rs");

#[cfg(test)]
mod tests {
    use super::*;

    fn parser_with(kinds: &[i32]) -> Box<@EXPECT_PREFIX@> {
        let parser = @EXPECT_PREFIX@::new(None).expect("construct generated parser");
        let stream = parser.get_i_prs_stream();
        {
            let mut stream = stream.borrow_mut();
            stream.make_token(0, 0, 0);
            for (index, kind) in kinds.iter().copied().enumerate() {
                let off = (index + 1) as i32;
                stream.make_token(off, off, kind);
            }
            let size = stream.get_size();
            stream.set_stream_length(size);
        }
        parser
    }

    fn parse_payload(
        parser: &mut @EXPECT_PREFIX@,
        repair: i32,
    ) -> Option<Box<dyn Any>> {
        parser
            .parser_with_monitor(repair, None)
            .expect("parser driver should not fail")
    }

    fn downcast_root(payload: Box<dyn Any>) -> Rc<Root> {
        let ast = unbox_ast(payload.as_ref()).expect("Rc<dyn IAst>");
        downcast_ast::<Root>(ast).expect("root should downcast to Root")
    }

    #[test]
    fn glr_recover_well_formed_and_repair() {
        // 1) Well-formed "a b c" — error-free GLR path
        let mut parser = parser_with(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_b,
            @EXPECT_PREFIX@sym::TK_c,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let payload = parse_payload(&mut parser, 0).expect("well-formed parse");
        let root = downcast_root(payload);
        assert_eq!(root.get_rule_index(), @EXPECT_PREFIX@sym::RULE_S);

        // 2) Malformed "a" with repair → Missing prosthesis
        let mut parser = parser_with(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let payload = parse_payload(&mut parser, 16).expect("repair parse");
        let root = downcast_root(payload);
        let missing = root.get_Missing().expect("Missing child");
        downcast_ast::<Missing>(missing).expect("child is Missing");

        // 3) Malformed "a" without repair → None after Diagnose
        let mut parser = parser_with(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        assert!(parse_payload(&mut parser, 0).is_none());

        // 4) Prosthetic factories still emitted under -glr
        let parser = parser_with(&[
            @EXPECT_PREFIX@sym::TK_a,
            @EXPECT_PREFIX@sym::TK_b,
            @EXPECT_PREFIX@sym::TK_c,
            @EXPECT_PREFIX@sym::TK_EOF_TOKEN,
        ]);
        let prosthetic = parser.get_prosthetic_ast();
        assert!(!prosthetic.is_empty(), "recover grammar must emit factories");
        let error_token = {
            let stream = parser.get_i_prs_stream();
            let stream = stream.borrow();
            stream.get_i_token(1).expect("stand-in error token")
        };
        let table = parser.get_parse_table();
        let nt_offset = table.get_nt_offset();
        let mut synthesized = 0;
        for kind in (nt_offset + 1)..=(nt_offset + table.get_num_nonterminals()) {
            let slot = table.get_prosthesis_index(kind);
            if slot < 0 || slot as usize >= prosthetic.len() {
                continue;
            }
            if let Some(factory) = &prosthetic[slot as usize] {
                let node = factory(error_token.clone());
                downcast_ast::<Missing>(node).expect("prosthetic Missing node");
                synthesized += 1;
            }
        }
        assert!(synthesized > 0, "the %Recover nonterminal must own a factory");
    }
}
